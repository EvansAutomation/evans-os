{
  "mcpServers": {
    "n8n-mcp": {
      "command": "npx",
      "args": ["n8n-mcp"],
      "env": {
        "MCP_MODE": "stdio",
        "LOG_LEVEL": "error",
        "DISABLE_CONSOLE_OUTPUT": "true",
        "N8N_API_URL": "https://n8n.evansautomation.tech",
        "N8N_API_KEY": "REPLACE_WITH_YOUR_N8N_API_KEY"
      }
    }
  }
}
